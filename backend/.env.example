PORT=4000
FRONTEND_ORIGIN=http://localhost:3000
CORS_ALLOW_LOCALHOST=1
TRUST_PROXY=loopback
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=300
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3
KOBOLD_BASE_URL=http://127.0.0.1:5001/v1
KOBOLD_MODEL=koboldcpp
# Optional remote fallback remains supported by the backend, but the UI is local-first.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: deep web search grounding via Tavily
TAVILY_API_KEY=
TAVILY_SEARCH_DEPTH=advanced

# IntelLedger reminder worker hardening defaults
INTELLEDGER_REMINDER_WORKER_ENABLED=1
INTELLEDGER_REMINDER_WORKER_INTERVAL_MS=60000
INTELLEDGER_REMINDER_WORKER_BATCH_SIZE=25
INTELLEDGER_REMINDER_MIN_INTERVAL_MS=900000
INTELLEDGER_REMINDER_WEBHOOK_URL=
INTELLEDGER_REMINDER_WEBHOOK_SECRET=
